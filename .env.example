# ──────────────────────────────────────────────────────
# Interactive Storyteller — .env.example
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────

# ── Required: Google Cloud ──────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLOUD_PROJECT=your_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT_NUMBER=your_project_number_here

# Use Vertex AI (true) or AI Studio (false)
GOOGLE_GENAI_USE_VERTEXAI=false

# ── Required: ElevenLabs ────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# ── Optional: IoT Lighting (Home Assistant) ─────────────
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your_long_lived_token_here
HA_LIGHT_ENTITY=light.living_room

# ── Cloud Storage ───────────────────────────────────────
GCS_ASSETS_BUCKET=your_assets_bucket_name
GCS_FINAL_VIDEOS_BUCKET=your_final_videos_bucket_name

# ── Cloud Run Job ───────────────────────────────────────
FFMPEG_JOB_NAME=storyteller-ffmpeg-assembler

# ── Frontend URLs ───────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
PROD_FRONTEND_ORIGIN=https://your-domain.com

# ── Story settings ───────────────────────────────────────
MAX_STORY_TURNS=16
LOCAL_STORYBOOK_MODE=1
STORYBOOK_PAGE_SECONDS=3
STORYBOOK_TITLE=Reading Rainbow Adventure
STORYBOOK_MIN_SCENES=2
STORYBOOK_WAIT_FOR_SCENES_SECONDS=12

# ── Image generation ─────────────────────────────────────
IMAGE_MODEL=gemini-2.0-flash-exp
IMAGE_SIZE=512px

# ── Audio / barge-in ─────────────────────────────────────
DISABLE_BARGE_IN=1
BARGE_IN_SUPPRESS_SECONDS=1.2

# ── Storybook TTS ────────────────────────────────────────
ENABLE_STORYBOOK_TTS=1
ENABLE_STORYBOOK_CAPTIONS=1
STORYBOOK_TTS_LANG=en-US
STORYBOOK_TTS_VOICE=en-US-Neural2-F
STORYBOOK_TTS_RATE=0.9
FORCE_STORYBOOK_TTS=0

# ── Storybook video enhancement ──────────────────────────
ENABLE_STORYBOOK_MUSIC=1
ENABLE_STORYBOOK_SFX=1
ENABLE_VEO_FINAL=0
VEO_FINAL_SCENE_COUNT=2

LOG_AGENT_UTTERANCES=1 
ALLOW_512PX=1

# ── Frontend Parental Gate ───────────────────────────────
NEXT_PUBLIC_REQUIRE_MATH=false
